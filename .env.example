ANTHROPIC_API_KEY=your_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Use one of the following Google OAuth options:
# 1. Full OAuth client JSON copied into an env var
GOOGLE_OAUTH_CLIENT_CONFIG_JSON=
# 2. Or client ID + client secret for a Google Web Application OAuth client
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# 3. Or local development fallback file
GOOGLE_CREDENTIALS_PATH=credentials.json

FRONTEND_ORIGIN=http://localhost:5173
FRONTEND_POST_AUTH_URL=http://localhost:5173
PUBLIC_BACKEND_URL=http://localhost:8000

SESSION_SECRET=replace-this-with-a-long-random-secret
SESSION_COOKIE_SECURE=false
SESSION_SAME_SITE=lax
ALLOW_INSECURE_OAUTH_TRANSPORT=true
